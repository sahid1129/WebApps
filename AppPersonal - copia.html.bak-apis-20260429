                const textBeforeCursor = text.slice(0, cursorPos);
                const match = textBeforeCursor.match(/@([a-zA-ZáéíóúÁÉÍÓÚñÑ]*)$/);
                
                if (match) {
                    const search = match[1].toLowerCase();
