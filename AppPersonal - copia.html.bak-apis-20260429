        function escapeHtml(value) {
            return String(value ?? '').replace(/[&<>"']/g, char => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' }[char]));
        }

        function ganttDate(value) {
            if (!value) return null;
            const parts = String(value).split('-').map(Number);
            if (parts.length !== 3 || parts.some(Number.isNaN)) return null;
            return new Date(parts[0], parts[1] - 1, parts[2]);
        }

        function ganttAddDays(date, days) {
            const next = new Date(date);
            next.setDate(next.getDate() + days);
            return next;
        }

        function ganttDiffDays(a, b) {
            const startA = new Date(a.getFullYear(), a.getMonth(), a.getDate());
            const startB = new Date(b.getFullYear(), b.getMonth(), b.getDate());
            return Math.round((startA - startB) / 86400000);
        }

        function ganttTaskStart(task) {
            return ganttDate(task.dateStart) || ganttDate(task.dateEnd) || new Date();
        }

        function ganttTaskEnd(task) {
            const start = ganttTaskStart(task);
            const explicitEnd = ganttDate(task.dateEnd);
            return explicitEnd && explicitEnd >= start ? explicitEnd : start;
        }

        function getTaskDurationDays(startValue, endValue) {
            const start = ganttDate(startValue);
            const end = ganttDate(endValue);
            if (!start && !end) return 1;
            if (start && end && end >= start) return ganttDiffDays(end, start) + 1;
            return 1;
        }

        function ganttIsCompact() {
            return document.getElementById('gantt-density')?.value === 'compact';
        }

        function ganttRowHeight(row) {
            if (ganttIsCompact()) {
                if (row.type === 'group') return 34;
                if (row.type === 'role') return 28;
                return 32;
            }
            if (row.type === 'group') return 58;
            if (row.type === 'role') return 44;
            return 52;
        }

        function ganttStatusColor(status) {
            return (ganttStatusMeta[status || 'backlog'] || ganttStatusMeta.backlog).color;
        }

        function ganttSmartColor(task, role) {
            if (task.status === 'done') return '#10b981';
            const end = ganttTaskEnd(task);
            const isLate = task.status !== 'done' && end < new Date();
            if (isLate) return '#ef4444';
            if (task.status === 'review') return '#a855f7';
            if (task.status === 'progress') return role?.color || '#6366f1';
            return ganttStatusColor(task.status);
        }

        function setupGanttScrollSync() {
            const left = document.querySelector('.gantt-left');
            const right = document.querySelector('.gantt-right');
            if (!left || !right || left.dataset.synced === 'true') return;
            left.dataset.synced = 'true';
            right.dataset.synced = 'true';
            let locking = false;
            const sync = (source, target) => {
                if (locking) return;
                locking = true;
                target.scrollTop = source.scrollTop;
                requestAnimationFrame(() => { locking = false; });
            };
            left.addEventListener('scroll', () => sync(left, right));
            right.addEventListener('scroll', () => sync(right, left));
        }
        function ganttTaskProgress(task) {
            if (task.status === 'done') return 100;
            const subtasks = task.subtasks || [];
            if (subtasks.length) return Math.round((subtasks.filter(st => st.done).length / subtasks.length) * 100);
            if (task.status === 'review') return 80;
            if (task.status === 'progress') return 50;
            if (task.status === 'todo') return 15;
            return 0;
        }

        function ganttVisibleTasks() {
            return tasks.filter(t => {
                const activeStatus = ['backlog', 'todo', 'progress', 'review', 'done'].includes(t.status || 'backlog');
                const labelMatch = currentFilter === 'all' || (t.labels && t.labels.includes(currentFilter));
                const assigneeMatch = currentAssigneeFilter === 'all' || t.assignee === currentAssigneeFilter;
                return activeStatus && labelMatch && assigneeMatch;
            }).sort((a, b) => ganttTaskStart(a) - ganttTaskStart(b));
        }

        function ganttRows() {
            const rows = [];
            const statuses = ['backlog', 'todo', 'progress', 'review', 'done'];
            const visible = ganttVisibleTasks();
            statuses.forEach(status => {
                const statusTasks = visible.filter(t => (t.status || 'backlog') === status);
                if (!statusTasks.length) return;
                rows.push({ type: 'group', status });
                const roleIds = [...new Set(statusTasks.map(t => t.role || 'sin-rol'))];
                roleIds.forEach(roleId => {
                    const role = roles.find(r => r.id === roleId) || { id: roleId, name: roleId === 'sin-rol' ? 'Sin rol' : roleId, emoji: '◆', color: ganttStatusMeta[status].color };
                    rows.push({ type: 'role', status, role });
                    statusTasks.filter(t => (t.role || 'sin-rol') === roleId).forEach(task => {
                        rows.push({ type: 'task', status, role, task });
                        (task.subtasks || []).forEach((subtask, index) => rows.push({ type: 'subtask', status, role, task, subtask, index }));
                    });
                });
            });
            return rows;
        }


        function ganttIndicatorTasks() {
            const active = tasks.filter(t => ['backlog', 'todo', 'progress', 'review', 'done'].includes(t.status || 'backlog'));
            if ((config.ganttIndicatorScope || 'filtered') === 'all') return active;
            return ganttVisibleTasks();
        }

        function ganttProgressFromStatus(task) {
            const statuses = config.ganttProgressStatuses || ['review', 'done'];
            if (task.status === 'done' && statuses.includes('done')) return 100;
            if (task.status === 'review' && statuses.includes('review')) return 100;
            return 0;
        }
        
        function renderGanttView() {
            const table = document.getElementById('gantt-table');
            const months = document.getElementById('gantt-months');
            const days = document.getElementById('gantt-days');
            const grid = document.getElementById('gantt-grid');
            const bars = document.getElementById('gantt-bars');
            const body = document.getElementById('gantt-body');
            const timeline = document.getElementById('gantt-timeline');
            const todayLine = document.getElementById('gantt-today');
            const summary = document.getElementById('gantt-summary');
            if (!table || !months || !days || !grid || !bars || !body || !timeline || !summary) return;

            const visible = ganttVisibleTasks();
            const rows = ganttRows();
            
            // Indicador Resumen siempre usa el config base para Duración
            const configuredDays = Math.max(1, Number(config.projectDays || 30));
            const indicatorTasks = ganttIndicatorTasks();
            const advancedCount = indicatorTasks.filter(task => ganttProgressFromStatus(task) === 100).length;
            const progressPct = indicatorTasks.length ? Math.round((advancedCount / indicatorTasks.length) * 100) : 0;
            const people = new Set(indicatorTasks.map(t => t.assignee).filter(Boolean)).size;
            
            summary.innerHTML = [
                ['Tareas', indicatorTasks.length],
                ['Duración', `${configuredDays} días`],
                ['Avance', `${advancedCount}/${indicatorTasks.length} (${progressPct}%)`],
                ['Responsables', people]
            ].map(([label, value]) => `<div class="gantt-summary-pill glass-ui"><p class="text-[9px] font-black text-slate-500 dark:text-slate-400 uppercase tracking-widest">${label}</p><strong class="text-lg font-black text-slate-900 dark:text-white">${value}</strong></div>`).join('');

            if (!visible.length) {
                table.innerHTML = '<div class="p-10 text-center text-xs font-black text-slate-500 uppercase">No hay tareas para los filtros actuales</div>';
                months.innerHTML = days.innerHTML = grid.innerHTML = bars.innerHTML = '';
                return;
            }

            const starts = visible.map(ganttTaskStart);
            const minDate = ganttAddDays(new Date(Math.min(...starts)), -2); // Margen a la izquierda
            
            // Calcular máximo para que encaje exacto o con padding
            const configuredEnd = ganttAddDays(new Date(Math.min(...starts)), configuredDays - 1);
            const ends = visible.map(ganttTaskEnd);
            const maxDate = ganttAddDays(new Date(Math.max(...ends, configuredEnd)), 3); // Padding
            
            const totalDays = Math.max(1, ganttDiffDays(maxDate, minDate) + 1);
            const rightViewport = document.querySelector('.gantt-right')?.clientWidth || 760;
            
            // Ajuste especial para que la vista compacta apriete todos los días sin scroll
            const fittedDayWidth = Math.max(2, Math.floor(rightViewport / Math.max(totalDays, 1)));
            const dayWidth = ganttIsCompact() ? fittedDayWidth : 54;
            
            const totalHeight = rows.reduce((sum, row) => sum + ganttRowHeight(row), 0);
            const dayList = Array.from({ length: totalDays }, (_, index) => ganttAddDays(minDate, index));
            const template = `repeat(${totalDays}, ${dayWidth}px)`;
            months.style.gridTemplateColumns = template;
            days.style.gridTemplateColumns = template;
            grid.style.gridTemplateColumns = template;
            timeline.style.width = `${totalDays * dayWidth}px`;
            body.style.height = `${totalHeight}px`;

            const monthSpans = [];
            dayList.forEach(date => {
                const key = `${date.getFullYear()}-${date.getMonth()}`;
                const last = monthSpans[monthSpans.length - 1];
                if (last && last.key === key) last.span += 1;
                else monthSpans.push({ key, span: 1, label: date.toLocaleDateString('es-PE', { month: 'long', year: 'numeric' }) });
            });
            months.innerHTML = monthSpans.map(month => `<div class="gantt-month" style="grid-column: span ${month.span}">${month.label}</div>`).join('');
            days.innerHTML = dayList.map(date => `<div class="gantt-day ${[0,6].includes(date.getDay()) ? 'weekend' : ''}">${date.toLocaleDateString('es-PE', { weekday: 'short' }).slice(0, 1).toUpperCase()} ${String(date.getDate()).padStart(2, '0')}</div>`).join('');
            grid.innerHTML = dayList.map(date => `<div class="gantt-grid-day ${[0,6].includes(date.getDay()) ? 'weekend' : ''}"></div>`).join('');

            table.innerHTML = rows.map(row => {
                const heightStyle = `style="min-height:${ganttRowHeight(row)}px"`;
                if (row.type === 'group') {
                    const meta = ganttStatusMeta[row.status];
                    const count = visible.filter(t => (t.status || 'backlog') === row.status).length;
                    const statusTasks = visible.filter(t => (t.status || 'backlog') === row.status);
                    const statusDays = statusTasks.length ? (ganttDiffDays(new Date(Math.max(...statusTasks.map(ganttTaskEnd))), new Date(Math.min(...statusTasks.map(ganttTaskStart)))) + 1) : 0;
                    return `<div class="gantt-group-row text-[10px] uppercase" ${heightStyle}><div class="gantt-cell"><span class="gantt-group-dot" style="background:${meta.color}"></span>${meta.label}</div><div class="gantt-cell">${count} tareas</div><div class="gantt-cell"><span class="gantt-status-pill" style="background:${meta.color}">Estado</span></div><div class="gantt-cell"><span class="gantt-time-pill">${statusDays}d</span></div></div>`;
                }
                if (row.type === 'role') {
                    const roleTasks = visible.filter(t => (t.status || 'backlog') === row.status && (t.role || 'sin-rol') === row.role.id);
                    return `<div class="gantt-role-row text-[10px] uppercase" ${heightStyle}><div class="gantt-cell">${row.role.emoji || '◆'} Rol: ${escapeHtml(row.role.name)}</div><div class="gantt-cell">${roleTasks.length} asignadas</div><div class="gantt-cell"></div><div class="gantt-cell"></div></div>`;
                }
                const task = row.task;
                const meta = ganttStatusMeta[task.status || 'backlog'];
                if (row.type === 'subtask') {
                    const duration = Math.max(1, Number(row.subtask.durationDays || row.subtask.duration || 1));
                    return `<div class="gantt-data-row subtask-row text-[10px]" ${heightStyle}><div class="gantt-cell"><div class="gantt-task-stack"><span class="gantt-task-title gantt-subtask-title">↳ ${escapeHtml(row.subtask.title || 'Subtarea')}</span><span class="gantt-task-meta">Subtarea de ${escapeHtml(task.title)}</span></div></div><div class="gantt-cell">${escapeHtml(task.assignee || 'S/A')}</div><div class="gantt-cell"><span class="gantt-status-pill" style="background:${row.subtask.done ? '#10b981' : meta.color}">${row.subtask.done ? 'Hecha' : 'Pendiente'}</span></div><div class="gantt-cell"><span class="gantt-time-pill">${duration}d</span></div></div>`;
                }
                const duration = ganttDiffDays(ganttTaskEnd(task), ganttTaskStart(task)) + 1;
                const labelText = (task.labels || []).join(' · ') || 'Sin etiquetas';
                return `<div class="gantt-data-row text-[10px] cursor-pointer" ${heightStyle} onclick="window.editTask('${task.id}')"><div class="gantt-cell" style="border-left-color:${meta.color}"><div class="gantt-task-stack"><span class="gantt-task-title font-black text-slate-800 dark:text-slate-100">${escapeHtml(task.title)}</span><span class="gantt-task-meta">${escapeHtml(labelText)}</span></div></div><div class="gantt-cell">${escapeHtml(task.assignee || 'S/A')}</div><div class="gantt-cell"><span class="gantt-status-pill" style="background:${meta.color}">${meta.label}</span></div><div class="gantt-cell"><span class="gantt-time-pill">${duration}d</span></div></div>`;
            }).join('');

            bars.innerHTML = rows.map((row) => {
                const heightStyle = `style="min-height:${ganttRowHeight(row)}px"`;
                if (row.type === 'group') return `<div class="gantt-chart-group" ${heightStyle}></div>`;
                if (row.type === 'role') return `<div class="gantt-chart-role" ${heightStyle}></div>`;
                const task = row.task;
                const taskStart = ganttTaskStart(task);
                let start = taskStart;
                let end = ganttTaskEnd(task);
                let progress = ganttTaskProgress(task);
                let title = task.title;
                let isSubtask = false;
                let color = ganttSmartColor(task, row.role);
                if (row.type === 'subtask') {
                    const taskDuration = Math.max(1, ganttDiffDays(ganttTaskEnd(task), taskStart) + 1);
                    const usedBefore = (task.subtasks || []).slice(0, row.index).reduce((sum, st) => sum + Math.max(1, Number(st.durationDays || st.duration || 1)), 0);
                    const rawDuration = Math.max(1, Number(row.subtask.durationDays || row.subtask.duration || 1));
                    const safeOffset = Math.min(usedBefore, taskDuration - 1);
                    const safeDuration = Math.max(1, Math.min(rawDuration, taskDuration - safeOffset));
                    start = ganttAddDays(taskStart, safeOffset);
                    end = ganttAddDays(start, safeDuration - 1);
                    progress = row.subtask.done ? 100 : 0;
                    title = row.subtask.title || 'Subtarea';
                    color = row.subtask.done ? '#10b981' : ganttSmartColor(task, row.role);
                    isSubtask = true;
                }
                const left = ganttDiffDays(start, minDate) * dayWidth;
                const width = Math.max((ganttDiffDays(end, start) + 1) * dayWidth - (ganttIsCompact() ? 2 : 8), isSubtask ? 20 : 30);
                const overdue = task.status !== 'done' && end < new Date();
                return `<div class="gantt-chart-row" ${heightStyle}><button type="button" onclick="window.editTask('${task.id}')" class="gantt-bar ${isSubtask ? 'subtask' : 'task-main'} ${overdue ? 'overdue' : ''}" style="left:${left}px;width:${width}px;background:${color};--progress:${progress}%"><span>${escapeHtml(title)}</span></button></div>`;
            }).join('');

            const today = new Date();
            const todayOffset = ganttDiffDays(today, minDate) * dayWidth + dayWidth / 2;
            todayLine.style.left = `${todayOffset}px`;
            todayLine.style.display = todayOffset >= 0 && todayOffset <= totalDays * dayWidth ? 'block' : 'none';
        }

