        window.deleteRole = async (id) => { 
            if (!id) return;
            if (confirm("¿Estás seguro de que deseas eliminar este rol permanentemente?")) {
                try {
                    await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'roles', id));
                } catch (err) {
                    window.showAlert("Error al eliminar el rol: " + err.message);
                }
            } 
        };
        
        function parseDateLocal(dateStr) {
            if(!dateStr) return new Date();
            const [y, m, d] = dateStr.split('-').map(Number);
            return new Date(y, m - 1, d);
        }

        const taskForm = document.getElementById('task-form');
        if (taskForm) {
            taskForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                try {
                    const id = document.getElementById('edit-id').value;
                    
                    // --- VALIDACIÓN LIMITANTE DEL PROYECTO ---
                    const configuredDays = Math.max(1, Number(config.projectDays || 30));
                    let earliestStart = null;
                    tasks.forEach(t => {
                        if (t.id !== id && t.dateStart) {
                            const d = parseDateLocal(t.dateStart).getTime();
                            if (!earliestStart || d < earliestStart) earliestStart = d;
                        }
                    });
                    
                    const formDateStartRaw = document.getElementById('task-date-start').value;
                    const currentTaskStart = parseDateLocal(formDateStartRaw).getTime();
                    if (!earliestStart || currentTaskStart < earliestStart) {
                        earliestStart = currentTaskStart;
                    }
                    
                    const maxAllowedEndMs = earliestStart + ((configuredDays - 1) * 86400000);
                    const formDateEndRaw = document.getElementById('task-date-end').value || formDateStartRaw;
                    const currentTaskEndMs = parseDateLocal(formDateEndRaw).getTime();
                    
                    if (currentTaskEndMs > maxAllowedEndMs) {
                        const maxDateObj = new Date(maxAllowedEndMs);
                        const maxDateStr = `${maxDateObj.getFullYear()}-${String(maxDateObj.getMonth() + 1).padStart(2, '0')}-${String(maxDateObj.getDate()).padStart(2, '0')}`;
                        window.showAlert(`Vigencia de Proyecto Excedida: El proyecto dura un máximo de ${configuredDays} días. La fecha fin de la tarea no puede superar el límite del ${maxDateStr}.`);
                        return; // Bloquear guardado
                    }
                    // ------------------------------------------

                    const labelsInput = document.getElementById('task-labels').value;
                    const labels = labelsInput ? labelsInput.split(',').map(l => l.trim().startsWith('#') ? l.trim() : '#' + l.trim()).filter(l => l !== '#') : [];

                    // Extraer Links Dinámicos
                    const linksContainer = document.getElementById('task-links-container');
                    const links = Array.from(linksContainer.querySelectorAll('.link-input')).map(i => i.value.trim()).filter(v => v);
                    
                    // Extraer Subtareas Dinámicas
                    const subtasksContainer = document.getElementById('task-subtasks-container');
                    const subtasks = Array.from(subtasksContainer.querySelectorAll('.subtask-item')).map(div => {
                        const titleInput = div.querySelector('.subtask-title-input');
                        const cbInput = div.querySelector('.subtask-done-cb');
                        const durationInput = div.querySelector('.subtask-duration-input');
                        return {
                            title: titleInput ? titleInput.value.trim() : '',
                            done: cbInput ? cbInput.checked : false,
                            durationDays: Math.max(1, Number(durationInput ? durationInput.value : 1) || 1)
                        };
                    }).filter(st => st.title);

                    const parentDuration = getTaskDurationDays(document.getElementById('task-date-start').value, document.getElementById('task-date-end').value);
                    const subtasksDuration = subtasks.reduce((sum, st) => sum + (Number(st.durationDays) || 1), 0);
                    if (subtasks.length && subtasksDuration > parentDuration) {
                        window.showAlert(`Duración inválida: las subtareas suman ${subtasksDuration} días y la tarea principal dura ${parentDuration} días.`);
                        return;
                    }

                    const data = {
                        title: document.getElementById('task-title').value, 
                        role: document.getElementById('task-role').value,
                        assignee: document.getElementById('task-assignee').value, 
                        status: document.getElementById('task-status').value || 'backlog',
                        dateStart: document.getElementById('task-date-start').value, 
                        dateEnd: document.getElementById('task-date-end').value,
                        labels: labels, 
                        links: links, 
                        subtasks: subtasks,
                        updatedBy: currentUser, 
                        timestamp: Date.now()
                    };

                    const roleObj = roles.find(r => r.id === data.role);
                    const roleName = roleObj ? roleObj.name.toLowerCase() : '';
                    const titleLower = (data.title || '').toLowerCase();

                    if (data.status === 'done' && (roleName.includes('dax') || titleLower.includes('dax'))) {
                        const pendingModel = tasks.filter(t => t.id !== id && (t.title.toLowerCase().includes('modelo') || t.title.toLowerCase().includes('relación')) && t.status !== 'done');
                        if (pendingModel.length > 0) {
                            window.showAlert(`Bloqueo: Finaliza el Modelo de Datos antes del DAX.`);
                            return;
                        }
                    }

                    if (id) {
                        await updateDoc(doc(db, 'artifacts', appId, 'public', 'data', 'tasks', id), data);
                    } else {
                        data.comments = [];
                        await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'tasks'), data);
                    }
                    window.closeModal();
                } catch (err) {
                    console.error("Error capturado al guardar: ", err);
                    window.showAlert("Error al guardar tarea: " + err.message);
                }
            });
        }

        window.renderUI = renderUI;
        window.renderGanttView = renderGanttView;

        init();
    </script>
</body>
</html>