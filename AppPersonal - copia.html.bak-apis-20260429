        window.addComment = async () => {
            const id = document.getElementById('edit-id').value;
            const text = document.getElementById('comment-input').value.trim();
            if (!id || !text) return;
            const task = tasks.find(t => t.id === id);
            const newComments = [...(task.comments || []), { user: currentUser, text, date: new Date().toLocaleString() }];
            
            const lowerText = text.toLowerCase();
            for (const u of registeredUsers) {
                if (u.name !== currentUser) {
                    const firstName = u.name.split(' ')[0].toLowerCase();
                    const cleanFullName = u.name.toLowerCase().replace(/\s/g, '');
                    if (lowerText.includes('@' + firstName) || lowerText.includes('@' + cleanFullName) || lowerText.includes('@' + u.name.toLowerCase())) {
                        const newNotif = { id: Date.now().toString(), taskId: id, taskTitle: task.title, from: currentUser, read: false, timestamp: Date.now() };
                        updateDoc(doc(db, 'artifacts', appId, 'public', 'data', 'users', u.id), { notifications: [...(u.notifications || []), newNotif] });
                    }
                }
            }

            const me = registeredUsers.find(u => u.name === currentUser);
            if (me && me.notifications) {
                let changed = false;
                const myNotifs = me.notifications.map(n => {
                    if (n.taskId === id && !n.read) { changed = true; return { ...n, read: true }; }
                    return n;
                });
                if (changed) updateDoc(doc(db, 'artifacts', appId, 'public', 'data', 'users', me.id), { notifications: myNotifs });
            }

            await updateDoc(doc(db, 'artifacts', appId, 'public', 'data', 'tasks', id), { comments: newComments });
            document.getElementById('comment-input').value = '';
            renderComments(newComments);
        };

