<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KAN BAN Presonal - Cloud</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        // CONFIGURACIÓN CRÍTICA: Activar modo oscuro por clase en Tailwind
        tailwind.config = {
            darkMode: 'class',
        }
        
        // Prevenir flash de luz si el modo noche está activo
        if (localStorage.getItem('bi_kanban_theme') === 'dark') {
            document.documentElement.classList.add('dark');
        }
    </script>
    <style>
        /* TRANSICIÓN BASE Y FONDOS MULTICOLOR INTACTOS */
        body { 
            transition: background-color 0.4s, color 0.4s; 
            background-color: #f8fafc; 
            background-image: radial-gradient(at 0% 0%, hsla(210, 100%, 95%, 1) 0px, transparent 50%),
                              radial-gradient(at 100% 0%, hsla(280, 100%, 95%, 1) 0px, transparent 50%);
            background-attachment: fixed;
            color: #1e293b; 
        }
        
        html.dark body { 
            background-color: #0b0f19; 
            background-image: radial-gradient(at 0% 0%, hsla(220, 50%, 15%, 1) 0px, transparent 50%),
                              radial-gradient(at 100% 0%, hsla(280, 40%, 15%, 1) 0px, transparent 50%);
            color: #e2e8f0; 
        }

        /* --- SISTEMA DE DISEÑO DINÁMICO (BLANCO LIMPIO / NEGRO GLASS) --- */
        
        /* MODO DÍA: Blanco Limpio y Cómodo */
        .glass-ui {
            background-color: #ffffff;
            border: 1px solid #e2e8f0;
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
        }

        /* MODO NOCHE: Negro Translúcido */
        html.dark .glass-ui {
            background-color: rgba(30, 41, 59, 0.6);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(71, 85, 105, 0.4);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        /* --- EFECTO HOVER AMARILLO GLOBAL PARA TODOS LOS BOTONES --- */
        button, a.btn-global-hover {
            transition: all 0.3s ease !important;
        }
        
        /* Hover en MODO DÍA */
        button:not(.no-yellow-hover):hover, a.btn-global-hover:hover {
            background-color: #fef08a !important; 
            color: #713f12 !important; 
            border-color: #fde047 !important; 
            box-shadow: 0 4px 10px rgba(250, 204, 21, 0.2) !important;
            transform: translateY(-1px);
        }
        
        /* Hover en MODO NOCHE */
        html.dark button:not(.no-yellow-hover):hover, html.dark a.btn-global-hover:hover {
            background-color: #facc15 !important; 
            color: #422006 !important; 
            border-color: #eab308 !important; 
            box-shadow: 0 4px 10px rgba(234, 179, 8, 0.2) !important;
        }
        /* ------------------------------------------------------------------- */

        .kanban-column {
            min-height: 70vh;
            border-radius: 1.5rem;
            padding: 1.25rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            min-width: 320px;
        }
        
        /* Tarjetas y Animaciones */
        .task-card { cursor: grab; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); border: 1px solid #e2e8f0; }
        .task-card:active { cursor: grabbing; transform: scale(0.98); }
        .task-card:hover { transform: translateY(-4px); box-shadow: 0 15px 25px -5px rgba(0, 0, 0, 0.15); background-color: #ffffff !important; }
        html.dark .task-card { border-color: rgba(71, 85, 105, 0.5); }
        html.dark .task-card:hover { box-shadow: 0 15px 25px -5px rgba(0, 0, 0, 0.4); background-color: rgba(30, 41, 59, 0.9) !important; }
        
        .drag-over { filter: brightness(1.1); transform: scale(1.02); border: 2px dashed #818cf8 !important; }
        html.dark .drag-over { filter: brightness(1.3); }

        /* Overlays y Scrollbars */
        .glass-overlay { background-color: rgba(15, 23, 42, 0.5); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); }
        .custom-scrollbar::-webkit-scrollbar { width: 8px; height: 8px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(148, 163, 184, 0.5); border-radius: 10px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(148, 163, 184, 0.8); }
        html.dark .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(71, 85, 105, 0.6); }
        html.dark .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(100, 116, 139, 0.8); }
        
        /* Animaciones para Subtareas */
        .subtask-item { transition: all 0.2s ease-in-out; }
    
        /* --- PESTAÑA GANTT INTEGRADA AL KANBAN --- */
        .gantt-shell { min-height: 70vh; }
        .gantt-board { display: grid; grid-template-columns: 420px minmax(720px, 1fr); overflow: hidden; }
        .gantt-left, .gantt-right { max-height: 72vh; overflow: auto; }
        .gantt-left { border-right: 2px solid #cbd5e1; }
        html.dark .gantt-left { border-right-color: rgba(71, 85, 105, 0.45); }
        .gantt-head-row, .gantt-data-row, .gantt-group-row, .gantt-role-row { display: grid; grid-template-columns: 1.6fr .8fr .7fr .8fr; align-items: center; min-height: 42px; border-bottom: 1px solid #cbd5e1; }
        html.dark .gantt-head-row, html.dark .gantt-data-row, html.dark .gantt-group-row, html.dark .gantt-role-row { border-bottom-color: rgba(71, 85, 105, 0.35); }
        
        /* Headers Resaltados en Modo Día para el Gantt */
        .gantt-head-row { position: sticky; top: 0; z-index: 10; background: #e2e8f0; color: #0f172a; font-weight: 900; }
        html.dark .gantt-head-row { background: rgba(15, 23, 42, .96); color: #94a3b8; }
        
        .gantt-cell { padding: 0 14px; min-width: 0; }
        .gantt-group-row { background: rgba(224, 231, 255, .8); font-weight: 900; }
        html.dark .gantt-group-row { background: rgba(49, 46, 129, .18); }
        .gantt-role-row { background: rgba(241, 245, 249, .9); color: #475569; font-weight: 900; }
        html.dark .gantt-role-row { background: rgba(30, 41, 59, .45); color: #cbd5e1; }
        .gantt-task-title { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .gantt-subtask-title { padding-left: 22px; color: #64748b; }
        html.dark .gantt-subtask-title { color: #cbd5e1; }
        .gantt-timeline { position: relative; width: max-content; min-width: 100%; }
        
        /* Timelines Headers Resaltados */
        .gantt-months, .gantt-days { display: grid; position: sticky; top: 0; z-index: 8; background: #e2e8f0; color: #0f172a; }
        html.dark .gantt-months, html.dark .gantt-days { background: rgba(15, 23, 42, .96); color: #94a3b8; }
        .gantt-months { height: 28px; }
        .gantt-days { top: 28px; height: 34px; border-bottom: 2px solid #cbd5e1; }
        html.dark .gantt-days { border-bottom-color: rgba(71, 85, 105, .45); }
        
        .gantt-month, .gantt-day { border-right: 1px solid #cbd5e1; display: flex; align-items: center; justify-content: center; }
        html.dark .gantt-month, html.dark .gantt-day { border-right-color: rgba(71, 85, 105, .35); }
        .gantt-month { justify-content: flex-start; padding-left: 10px; }
        .gantt-day.weekend, .gantt-grid-day.weekend { background: rgba(203, 213, 225, 0.4); }
        html.dark .gantt-day.weekend, html.dark .gantt-grid-day.weekend { background: rgba(30, 41, 59, .5); }
        
        .gantt-body { position: relative; }
        .gantt-grid { position: absolute; inset: 0; display: grid; pointer-events: none; z-index: 0; }
        .gantt-grid-day { border-right: 1px solid #e2e8f0; }
        html.dark .gantt-grid-day { border-right-color: rgba(71, 85, 105, .28); }
        .gantt-bars { position: relative; z-index: 1; }
        .gantt-chart-row, .gantt-chart-group, .gantt-chart-role { position: relative; min-height: 42px; border-bottom: 1px solid #cbd5e1; }
        .gantt-chart-group { background: rgba(224, 231, 255, .5); }
        .gantt-chart-role { background: rgba(241, 245, 249, .6); }
        html.dark .gantt-chart-row, html.dark .gantt-chart-group, html.dark .gantt-chart-role { border-bottom-color: rgba(71, 85, 105, .35); }
        .gantt-bar { position: absolute; top: 10px; height: 22px; border-radius: .75rem; color: white; padding: 0 10px; display: flex; align-items: center; gap: 6px; font-size: 10px; font-weight: 900; overflow: hidden; white-space: nowrap; box-shadow: 0 10px 18px rgba(15, 23, 42, .14); cursor: pointer; }
        .gantt-bar::after { content: ''; position: absolute; inset: 0; width: var(--progress); background: rgba(255,255,255,.24); pointer-events: none; }
        .gantt-bar span { position: relative; z-index: 1; overflow: hidden; text-overflow: ellipsis; }
        .gantt-bar.subtask { height: 16px; top: 13px; opacity: .85; }
        .gantt-today { position: absolute; top: -62px; bottom: 0; width: 2px; background: rgba(79, 70, 229, .75); z-index: 5; pointer-events: none; }
        .gantt-summary-pill { border-radius: 1rem; padding: .75rem 1rem; }
        @media (max-width: 1100px) { .gantt-board { grid-template-columns: 360px minmax(620px, 1fr); } }

        /* --- MEJORAS DE JERARQUÍA Y SCROLL SINCRONIZADO GANTT --- */
        .gantt-board { grid-template-columns: 500px minmax(760px, 1fr); }
        .gantt-head-row, .gantt-data-row, .gantt-group-row, .gantt-role-row { grid-template-columns: 2.1fr 1fr .8fr .7fr; }
        .gantt-left, .gantt-right { scroll-behavior: smooth; }
        .gantt-group-row, .gantt-chart-group { min-height: 48px; }
        .gantt-role-row, .gantt-chart-role { min-height: 38px; }
        .gantt-data-row, .gantt-chart-row { min-height: 44px; }
        .gantt-group-row .gantt-cell:first-child { display: flex; align-items: center; gap: .65rem; }
        .gantt-group-dot { width: 12px; height: 12px; border-radius: 999px; box-shadow: 0 0 0 4px rgba(99, 102, 241, .12); flex: 0 0 auto; }
        .gantt-role-row .gantt-cell:first-child { padding-left: 28px; }
        .gantt-data-row .gantt-cell:first-child { padding-left: 44px; border-left: 3px solid transparent; }
        .gantt-data-row.subtask-row .gantt-cell:first-child { padding-left: 72px; }
        .gantt-task-stack { min-width: 0; display: grid; gap: 2px; }
        .gantt-task-meta { color: #64748b; font-size: 9px; font-weight: 900; text-transform: uppercase; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        html.dark .gantt-task-meta { color: #94a3b8; }
        .gantt-status-pill { display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; padding: 4px 8px; color: white; font-size: 9px; font-weight: 900; }
        .gantt-time-pill { display: inline-flex; align-items: center; justify-content: center; min-width: 44px; border-radius: 999px; padding: 4px 8px; background: #f1f5f9; color: #334155; font-weight: 900; }
        html.dark .gantt-time-pill { background: rgba(51, 65, 85, .75); color: #e2e8f0; }
        .gantt-bar { border: 1px solid rgba(255,255,255,.22); }
        .gantt-bar.subtask { border-radius: .55rem; }
        .gantt-bar.overdue { box-shadow: 0 0 0 3px rgba(239, 68, 68, .18), 0 10px 18px rgba(15, 23, 42, .14); }
        .subtask-duration-input { max-width: 92px; }
        @media (max-width: 1100px) { .gantt-board { grid-template-columns: 420px minmax(680px, 1fr); } }

        /* --- AJUSTES FINALES GANTT: SCROLL ÚNICO, DENSIDAD Y COLOR --- */
        body { background-image: radial-gradient(at 0% 0%, hsla(210, 100%, 94%, 1) 0px, transparent 46%), radial-gradient(at 88% 12%, hsla(265, 95%, 94%, .95) 0px, transparent 42%), radial-gradient(at 50% 100%, hsla(175, 80%, 92%, .8) 0px, transparent 42%); }
        html.dark body { background-image: radial-gradient(at 0% 0%, hsla(220, 70%, 18%, 1) 0px, transparent 48%), radial-gradient(at 100% 0%, hsla(282, 55%, 20%, .95) 0px, transparent 45%), radial-gradient(at 48% 100%, hsla(190, 55%, 15%, .75) 0px, transparent 42%); }
        .glass-ui { box-shadow: 0 14px 35px -28px rgba(79, 70, 229, .42), 0 1px 3px rgba(15, 23, 42, .08); }
        html.dark .glass-ui { box-shadow: 0 0 0 1px rgba(129, 140, 248, .12), 0 18px 55px -34px rgba(56, 189, 248, .45); }
        .gantt-board { overflow: auto; max-height: 72vh; align-items: start; }
        .gantt-left, .gantt-right { max-height: none; overflow: visible; }
        .gantt-left { position: sticky; left: 0; z-index: 12; background: rgba(255,255,255,.94); backdrop-filter: blur(14px); }
        html.dark .gantt-left { background: rgba(15, 23, 42, .94); }
        .gantt-head-row { top: 0; }
        .gantt-months { top: 0; }
        .gantt-days { top: 28px; }
        .gantt-controls { display: flex; flex-wrap: wrap; gap: .75rem; align-items: center; justify-content: flex-end; }
        .gantt-density-select { min-width: 152px; }
        .gantt-chart-group { background: linear-gradient(90deg, rgba(99,102,241,.12), rgba(14,165,233,.06)); }
        html.dark .gantt-chart-group { background: linear-gradient(90deg, rgba(99,102,241,.22), rgba(14,165,233,.09)); }
        .gantt-chart-row { background: rgba(255,255,255,.5); }
        html.dark .gantt-chart-row { background: rgba(15,23,42,.08); }
        .gantt-bar.task-main { background-image: linear-gradient(90deg, rgba(255,255,255,.18), rgba(255,255,255,0)) !important; outline: 2px solid rgba(255,255,255,.42); outline-offset: -2px; }
        .gantt-bar.subtask { filter: saturate(.9) brightness(1.04); }
        html.dark .gantt-bar.task-main { box-shadow: 0 0 18px rgba(99,102,241,.28), 0 10px 18px rgba(0,0,0,.22); }
        .subtask-duration-wrap { display: grid; grid-template-columns: 1fr; gap: 3px; }
        .subtask-duration-wrap span { text-align: center; font-size: 8px; line-height: 1; font-weight: 900; color: #64748b; text-transform: uppercase; }
        html.dark .subtask-duration-wrap span { color: #94a3b8; }

        /* --- AJUSTE DE ALINEACIÓN E INDICADORES GANTT --- */
        .gantt-head-row { min-height: 62px; height: 62px; }
        .gantt-board.compact .gantt-head-row { min-height: 54px; height: 54px; }
        .gantt-board.compact .gantt-months { height: 24px; }
        .gantt-board.compact .gantt-days { top: 24px; height: 30px; }
        .gantt-board.compact .gantt-today { top: -54px; }
        .gantt-board.detailed .gantt-months { height: 30px; }
        .gantt-board.detailed .gantt-days { top: 30px; height: 32px; }
        .gantt-board.detailed .gantt-today { top: -62px; }
        .gantt-board.compact .gantt-day { font-size: 8px; }
        .gantt-board.compact .gantt-task-meta { display: none; }
        .gantt-board.compact .gantt-cell { padding-left: 10px; padding-right: 10px; }
        .gantt-indicator-option { display: flex; align-items: center; gap: .5rem; padding: .65rem .75rem; border-radius: .9rem; }
        .gantt-indicator-option input { width: 1rem; height: 1rem; }
    </style>
</head>
<body class="font-sans p-4 md:p-6 custom-scrollbar overflow-x-hidden">

    <!-- Cargando / Errores -->
    <div id="loading-overlay" class="fixed inset-0 flex items-center justify-center z-[400] glass-overlay">
        <div class="text-white text-center max-w-lg p-6 animate-pulse">
            <div id="loader-spinner" class="w-16 h-16 border-4 border-indigo-500 border-t-transparent rounded-full animate-spin mb-4 mx-auto"></div>
            <p id="loader-text" class="font-black uppercase tracking-widest text-xs">Conectando a Firebase...</p>
            <div id="loader-error-help" class="hidden mt-4 text-left glass-ui p-6 rounded-2xl">
                <p class="text-red-400 font-black mb-3 text-sm">⚠️ ERROR DE CONEXIÓN</p>
                <div id="detailed-error" class="mt-4 p-2 bg-black/40 rounded font-mono text-[10px] text-red-300 whitespace-pre-wrap"></div>
            </div>
        </div>
    </div>

    <!-- Pantalla de Autenticación Rediseñada -->
    <div id="auth-overlay" class="fixed inset-0 flex items-center justify-center p-4 z-[300] glass-overlay hidden">
        <div class="glass-ui !bg-white/80 dark:!bg-slate-800/90 rounded-[2rem] w-full max-w-xl overflow-hidden flex flex-col transition-all duration-300">
            <!-- Header Login -->
            <div class="bg-indigo-600/90 dark:bg-indigo-900/90 backdrop-blur-md p-8 text-center relative overflow-hidden">
                <div class="absolute -top-10 -right-10 w-40 h-40 bg-indigo-400/50 dark:bg-indigo-700/50 rounded-full blur-3xl opacity-50"></div>
                <div class="relative z-10">
                    <span class="text-5xl mb-4 block">📊</span>
                    <h2 class="text-3xl font-black text-white tracking-tighter uppercase">Kanban Cloud BI</h2>
                    <p class="text-indigo-100 text-sm font-medium mt-1">Gestión Colaborativa Segura</p>
                </div>
            </div>

            <!-- Body Login -->
            <div class="p-8">
                <!-- VISTA 1: Lista de usuarios (Login) -->
                <div id="login-view">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="text-sm font-black text-slate-800 dark:text-slate-200 uppercase tracking-widest">Selecciona tu perfil</h3>
                        <button onclick="toggleRegisterView(true)" class="text-[10px] glass-ui text-indigo-700 dark:text-indigo-300 px-3 py-1.5 rounded-lg font-black transition-all">➕ Nuevo</button>
                    </div>
                    <div id="auth-existing-list" class="grid grid-cols-2 sm:grid-cols-3 gap-3 max-h-48 overflow-y-auto custom-scrollbar p-1">
                        <!-- Generado por JS -->
                    </div>
                </div>

                <!-- VISTA 2: Registro de Usuario -->
                <div id="register-view" class="hidden">
                    <div class="flex items-center gap-3 mb-6 pb-4 border-b border-slate-200/50 dark:border-slate-600/50">
                        <button onclick="toggleRegisterView(false)" class="text-slate-600 dark:text-slate-400 font-bold">⬅️ Volver</button>
                        <h3 class="text-sm font-black text-slate-800 dark:text-slate-200 uppercase tracking-widest">Registrar Nuevo Usuario</h3>
                    </div>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-[10px] font-black text-slate-600 dark:text-slate-400 uppercase mb-1">Nombre Completo</label>
                            <input type="text" id="reg-name" placeholder="Ej. Juan Pérez" class="w-full glass-ui text-slate-900 dark:text-white rounded-xl p-3 text-sm font-bold focus:border-indigo-500/50 outline-none transition-colors">
                        </div>
                        <div>
                            <label class="block text-[10px] font-black text-slate-600 dark:text-slate-400 uppercase mb-1">Crea una clave (6 números)</label>
                            <input type="password" id="reg-pass" placeholder="******" maxlength="6" class="w-full glass-ui text-slate-900 dark:text-white rounded-xl p-3 text-center tracking-[0.5em] text-xl font-black focus:border-indigo-500/50 outline-none transition-colors">
                        </div>
                        <button onclick="registerNewUser()" class="w-full bg-emerald-500/90 text-white py-4 rounded-xl font-black shadow-lg uppercase tracking-widest mt-4 border border-emerald-400/50">
                            Crear Cuenta e Ingresar
                        </button>
                    </div>
                </div>

                <!-- VISTA 3: Pedir Clave (Login) -->
                <div id="password-view" class="hidden">
                    <div class="flex items-center gap-3 mb-6 pb-4 border-b border-slate-200/50 dark:border-slate-600/50">
                        <button onclick="hidePasswordView()" class="text-slate-600 dark:text-slate-400 font-bold">⬅️ Volver</button>
                        <h3 class="text-sm font-black text-slate-800 dark:text-slate-200 uppercase tracking-widest">Verificación de Seguridad</h3>
                    </div>
                    <div class="text-center mb-6">
                        <div id="login-avatar" class="w-16 h-16 glass-ui rounded-full mx-auto flex items-center justify-center text-xl font-black text-indigo-700 dark:text-indigo-300 mb-3"></div>
                        <p class="font-black text-slate-900 dark:text-white text-lg" id="login-name-display"></p>
                    </div>
                    <div class="space-y-4">
                        <input type="password" id="login-pass" placeholder="******" maxlength="6" class="w-full glass-ui text-slate-900 dark:text-white rounded-xl p-4 text-center tracking-[0.5em] text-2xl font-black focus:border-indigo-500/50 outline-none transition-colors">
                        <p id="password-help-msg" class="text-center text-xs font-bold text-amber-500 hidden">Actualización: Crea tu clave de 6 dígitos.</p>
                        <button onclick="executeLogin()" class="w-full bg-indigo-600/90 text-white py-4 rounded-xl font-black shadow-lg uppercase tracking-widest border border-indigo-500/50">
                            Acceder
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- HEADER PRINCIPAL -->
    <header class="mb-10 relative z-[60]">
        <div class="flex flex-col xl:flex-row justify-between items-start xl:items-center gap-8 mb-8">
            
            <div class="relative z-[100]">
                <h1 class="text-4xl font-black tracking-tighter mb-4 flex items-center gap-3">
                    <span class="text-blue-600 dark:text-blue-400 text-3xl">◆</span> 
                    <span class="text-blue-800 dark:text-blue-300">Kanban</span> 
                    <span class="text-amber-500 dark:text-amber-400 italic">Proyecto SAID</span>
                </h1>
                
                <div class="flex flex-wrap items-center gap-3">
                    <!-- Botón Usuario Glass -->
                    <span id="display-user" class="glass-ui text-slate-700 dark:text-slate-200 font-black text-xs px-5 py-2.5 rounded-full uppercase flex items-center gap-2 cursor-default">
                        👤 Invitado
                    </span>
                    
                    <!-- Usuarios Conectados & Notificaciones Glass -->
                    <div class="flex items-center gap-2 glass-ui px-4 py-1.5 rounded-full relative z-[110]">
                        <div id="online-users-container" class="flex -space-x-2"></div>
                        <div class="h-4 w-px bg-slate-200 dark:bg-slate-600 mx-1"></div>
                        
                        <!-- Campana -->
                        <div class="relative cursor-pointer group no-yellow-hover" onclick="toggleNotifications()">
                            <span class="text-lg hover:scale-110 transition-transform inline-block text-amber-500 dark:text-amber-400">🔔</span>
