            onSnapshot(doc(db, 'artifacts', appId, 'public', 'data', 'config', 'master'), (snap) => {
                if (snap.exists()) { 
                    config = { ...config, ...snap.data() }; 
                    updateStatusUI(); 
                    document.getElementById('btn-infopucp').href = config.infoPucpLink || '#';
                    
                    // Renderizar botones dinámicos en el header
                    const dynamicLinksContainer = document.getElementById('dynamic-quick-links');
                    if (dynamicLinksContainer) {
                        const customLinks = config.customLinks || [];
                        const htmlLinks = customLinks.map(l => `<a href="${l.url}" target="_blank" class="glass-ui text-slate-700 dark:text-slate-200 px-5 py-2.5 rounded-full text-[10px] font-black uppercase inline-block btn-global-hover">${l.title} 🔗</a>`).join('');
                        
                        dynamicLinksContainer.innerHTML = `
                            <a id="btn-infopucp" href="${config.infoPucpLink || '#'}" target="_blank" class="glass-ui text-slate-700 dark:text-slate-200 px-5 py-2.5 rounded-full text-[10px] font-black uppercase inline-block btn-global-hover">INFOPUCP 🎓</a>
                            ${htmlLinks}
                        `;
                    }
                } else { 
                    setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'config', 'master'), { available: true, link: '#', infoPucpLink: '#', customLinks: [] });
                }
            }, (err) => console.error("Config Sync Error:", err));
