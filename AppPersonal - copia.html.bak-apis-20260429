            onSnapshot(collection(db, 'artifacts', appId, 'public', 'data', 'roles'), (snap) => {
                roles = snap.docs.map(d => ({id: d.id, ...d.data()}));
                if (roles.length === 0) seedRoles();
                updateRoleSelects();
                renderRoleManager();
                renderUI();
            }, (err) => setLoaderError("Error al sincronizar Roles", err.message));

            onSnapshot(collection(db, 'artifacts', appId, 'public', 'data', 'tasks'), (snap) => {
                tasks = snap.docs.map(d => ({id: d.id, ...d.data()}));
                renderUI();
                document.getElementById('loading-overlay').classList.add('hidden');
            }, (err) => setLoaderError("Error al sincronizar Tareas", err.message));

            onSnapshot(collection(db, 'artifacts', appId, 'public', 'data', 'users'), (snap) => {
                registeredUsers = snap.docs.map(d => ({id: d.id, ...d.data()}));
                const me = registeredUsers.find(u => u.name === currentUser);
                if (me) window.updateNotificationsUI(me.notifications || []);
                renderTeamManager();
                window.renderOnlineUsers();
                window.renderAuthList();
