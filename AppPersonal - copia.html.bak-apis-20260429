            const taskId = ev.dataTransfer.getData("taskId");
            const task = tasks.find(t => t.id === taskId);
            if (task) {
                const roleObj = roles.find(r => r.id === task.role);
                const roleName = roleObj ? roleObj.name.toLowerCase() : '';
                const titleLower = (task.title || '').toLowerCase();

                if (newStatus === 'done' && (roleName.includes('dax') || titleLower.includes('dax'))) {
                    const pendingModel = tasks.filter(t => (t.title.toLowerCase().includes('modelo') || t.title.toLowerCase().includes('relación')) && t.status !== 'done');
                    if (pendingModel.length > 0) { window.showAlert(`Bloqueo: Finaliza el Modelo de Datos antes del DAX.`); return; }
                }
                await updateDoc(doc(db, 'artifacts', appId, 'public', 'data', 'tasks', taskId), { status: newStatus });
            }
